      "category": "controller"
    },
    {
      "ref": "M1",
      "part": "Servo Motors",
      "category": "motor"
    },
    {
      "ref": "M2",
      "part": "Servo Motors",
      "category": "motor"
    },
    {
      "ref": "DRV1",
      "part": "Servo Drivers",
      "category": "driver"
    },
    {
      "ref": "GRIP1",
      "part": "Grippers",
      "category": "actuator"
    },
    {
      "ref": "CAM1",
      "part": "Camera",
      "category": "sensor"
    }
  ],
  "nets": [
    {
      "name": "CAN_BUS",
      "connections": [
        "U1.CAN",
        "DRV1.CAN"
      ],
      "inferred": true
    },
    {
