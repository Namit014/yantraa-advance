# OpenRouter Settings
OPENROUTER_API_KEY=your_openrouter_api_key_here
OPENROUTER_MODEL=openrouter/auto

# Backend Configuration
# Comma-separated list of allowed frontend origins (no spaces)
# For production: include your Vercel domain
CORS_ORIGINS=http://localhost:3000,https://labs.yantraa.tech,https://www.labs.yantraa.tech
PORT=8000

# Qdrant Vector DB Path
# For local dev: ./qdrant_data
# For AWS production: /home/ubuntu/yantraa-advance/qdrant_data (absolute path)
QDRANT_DATA_PATH=./qdrant_data

# AWS S3 Configuration for CAD Files
# Use this if your bucket is public
S3_BUCKET_URL=https://your-bucket-name.s3.ap-south-1.amazonaws.com

# Use this if your bucket is PRIVATE (Generates 15-minute Pre-Signed URLs)
S3_BUCKET_NAME=your-bucket-name
AWS_ACCESS_KEY_ID=your_aws_access_key
AWS_SECRET_ACCESS_KEY=your_aws_secret_key
AWS_REGION=ap-south-1
